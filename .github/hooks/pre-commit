#!/usr/bin/env bash

set -euo pipefail

# Change to the repository root
cd "$(git rev-parse --show-toplevel)" || exit 1

source ./version

# Update chart version
if sed --version 2>/dev/null; then
    # Using GNU sed (Linux)
    sed -i "s/version: .*/version: $VERSION/" helm/promgithub/Chart.yaml
    sed -i "s/appVersion: .*/appVersion: \"$VERSION\"/" helm/promgithub/Chart.yaml
else
    # Using BSD sed (macOS)
    sed -i '' "s/version: .*/version: $VERSION/" helm/promgithub/Chart.yaml
    sed -i '' "s/appVersion: .*/appVersion: \"$VERSION\"/" helm/promgithub/Chart.yaml
fi

# Run go fmt to format the source code
make fmt

# Stage the changes if Chart.yaml and go source files are modified
git add helm/promgithub/Chart.yaml src/

echo "Pre-commit hook completed successfully"